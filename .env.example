# =============================================================================
# VERITY — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# --- App -----------------------------------------------------------------------
APP_ENV=development                     # development | staging | production
APP_SECRET_KEY=change-me-32-chars-min  # openssl rand -hex 32
APP_DEBUG=true
APP_LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
APP_CORS_ORIGINS=http://localhost:3000  # comma-separated list

# --- API Server ----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                           # increase in production

# --- Supabase (PostgreSQL + Auth) ----------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/verity
# For direct DB connections (migrations, admin):
DATABASE_DIRECT_URL=postgresql://postgres:password@localhost:5432/verity

# --- Redis / Upstash -----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Pinecone (Vector DB) ------------------------------------------------------
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=gcp-starter        # check your pinecone console
PINECONE_INDEX_NAME=verity-research

# --- LLM Providers -------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key      # GPT-4o fallback

# Primary model config
LLM_PRIMARY_MODEL=claude-sonnet-4-20250514
LLM_FALLBACK_MODEL=gpt-4o
LLM_TEMPERATURE=0.1                     # low for factual research tasks
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# --- Financial Data APIs -------------------------------------------------------
# Financial Modeling Prep (free: 250 calls/day)
FMP_API_KEY=your-fmp-api-key
FMP_BASE_URL=https://financialmodelingprep.com/api/v3

# Alpha Vantage (free: 25 calls/day — backup)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# NewsAPI (free: 100 calls/day)
NEWS_API_KEY=your-news-api-key
NEWS_API_BASE_URL=https://newsapi.org/v2

# SEC EDGAR (free, no key required — but set a descriptive User-Agent)
SEC_EDGAR_USER_AGENT="VERITY Research Platform contact@yourcompany.com"
SEC_EDGAR_BASE_URL=https://efts.sec.gov/LATEST/search-index
SEC_EDGAR_SUBMISSIONS_URL=https://data.sec.gov/submissions

# --- Embedding -----------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small  # OpenAI embedding model
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100
CHUNK_SIZE=512                           # tokens per chunk
CHUNK_OVERLAP=64                         # token overlap between chunks

# --- Rate Limiting -------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_DAY=1000

# --- Cost Tracking -------------------------------------------------------------
# Prices in USD per 1M tokens (update when pricing changes)
ANTHROPIC_INPUT_COST_PER_1M=3.00
ANTHROPIC_OUTPUT_COST_PER_1M=15.00
OPENAI_INPUT_COST_PER_1M=5.00
OPENAI_OUTPUT_COST_PER_1M=15.00
OPENAI_EMBEDDING_COST_PER_1M=0.02

# --- Job Configuration ---------------------------------------------------------
RESEARCH_JOB_TIMEOUT_SECONDS=600       # 10 min max per research job
MAX_CONCURRENT_JOBS=5
JOB_RETENTION_DAYS=90

# --- Observability -------------------------------------------------------------
# Datadog (optional — leave blank to disable)
DD_API_KEY=
DD_SERVICE=verity-backend
DD_ENV=development

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
